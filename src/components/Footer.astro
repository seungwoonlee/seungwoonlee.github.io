---
const today = new Date();
---

<footer>
	<div class="footer-content">
		&copy; {today.getFullYear()} SEUNGWOON LEE. <span class="luxury-tag">Digital Luxury Experience</span>
	</div>
	<div class="social-links">
		<a href="https://github.com/seungwoonlee" target="_blank">GitHub</a>
	</div>
</footer>

<style>
	footer {
		padding: 4em 1em 8em 1em;
		background: #0A0A0A;
		border-top: 1px solid #D4AF37;
		color: #A0A0A0;
		text-align: center;
		font-size: 0.8rem;
		letter-spacing: 1px;
	}
	.footer-content {
		margin-bottom: 1.5em;
		font-weight: 300;
		color: #FDFBF7;
	}
	.luxury-tag {
		color: #D4AF37;
		margin-left: 10px;
		font-style: italic;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 2em;
	}
	.social-links a {
		text-decoration: none;
		color: #D4AF37;
		transition: all 0.3s ease;
		font-weight: 600;
		text-transform: uppercase;
		font-size: 0.7rem;
	}
	.social-links a:hover {
		color: #FDFBF7;
		text-shadow: 0 0 8px #D4AF37;
	}
</style>
